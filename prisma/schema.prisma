generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth (Auth.js v5 required tables) ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  clients   Client[]
  proposals Proposal[]
  contracts Contract[]
  invoices  Invoice[]
  bookings  Booking[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core domain ─────────────────────────────────────────────────────────────

model Client {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String
  phone     String?
  company   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  proposals Proposal[]
  contracts Contract[]
  invoices  Invoice[]
  bookings  Booking[]
}

// ProposalStatus: DRAFT | SENT | VIEWED | ACCEPTED | DECLINED | EXPIRED
model Proposal {
  id         String    @id @default(cuid())
  userId     String
  clientId   String
  title      String
  body       String
  amount     Float
  currency   String    @default("USD")
  status     String    @default("DRAFT")
  validUntil DateTime?
  sentAt     DateTime?
  viewedAt   DateTime?
  acceptedAt DateTime?
  declinedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id])
  contract Contract?
}

// ContractStatus: DRAFT | SENT | PARTIALLY_SIGNED | SIGNED | VOIDED
model Contract {
  id             String    @id @default(cuid())
  userId         String
  clientId       String
  proposalId     String?   @unique
  title          String
  body           String
  status         String    @default("DRAFT")
  signedAt       DateTime?
  clientSignedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id])
  proposal Proposal? @relation(fields: [proposalId], references: [id])
  invoices Invoice[]
}

// InvoiceStatus: DRAFT | SENT | VIEWED | PARTIAL | PAID | OVERDUE | VOID
model Invoice {
  id         String    @id @default(cuid())
  userId     String
  clientId   String
  contractId String?
  number     String
  title      String
  lineItems  String    // JSON: [{description, qty, unitPrice}]
  subtotal   Float
  tax        Float     @default(0)
  total      Float
  currency   String    @default("USD")
  status     String    @default("DRAFT")
  dueDate    DateTime?
  sentAt     DateTime?
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client   Client    @relation(fields: [clientId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])
}

// BookingStatus: PENDING | CONFIRMED | CANCELLED | COMPLETED
model Booking {
  id        String    @id @default(cuid())
  userId    String
  clientId  String?
  title     String
  notes     String?
  status    String    @default("CONFIRMED")
  startAt   DateTime
  endAt     DateTime
  location  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id])
}
